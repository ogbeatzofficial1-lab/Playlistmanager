# VITE_GEMINI_API_KEY: Required for Gemini AI API calls in the browser app.
# Add this in your local env or hosting environment so the frontend can access it.
VITE_GEMINI_API_KEY="MY_GEMINI_API_KEY"
VITE_STEM_SPLIT_ENDPOINT="http://localhost:8000/stem-split"
STEM_SPLIT_PUBLIC_URL="https://your-stem-api.onrender.com"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# SUPABASE: Required for database and auth.
# Users configure these via the Secrets panel in the AI Studio UI.
VITE_SUPABASE_URL="https://your-project-id.supabase.co"
VITE_SUPABASE_ANON_KEY="your-anon-key"
# Optional image bucket for track/playlist artwork uploads (defaults to "assets")
VITE_SUPABASE_IMAGE_BUCKET="assets"
